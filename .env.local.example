# .env.local.example
# 이 파일을 복사해 .env.local로 만들고 실제 값을 채워주세요.
# .env.local은 .gitignore에 의해 git에 절대 올라가지 않습니다.

# ── 데이터베이스 ──────────────────────────────────────────
# Vercel Postgres, Supabase, Neon, Railway 등 무엇이든 PostgreSQL이면 됩니다.
# 예: postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
DATABASE_URL=

# ── Auth.js 자체 암호화 키 ───────────────────────────────
# 터미널에서 생성: npx auth secret
AUTH_SECRET=

# ── Google 로그인 ───────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# OAuth Client ID 생성 시 승인된 리디렉션 URI에 아래 주소 등록:
#   http://localhost:3000/api/auth/callback/google  (로컬)
#   https://내도메인/api/auth/callback/google        (배포)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Kakao 로그인 ─────────────────────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → 카카오 로그인 활성화
# Redirect URI 등록:
#   http://localhost:3000/api/auth/callback/kakao
#   https://내도메인/api/auth/callback/kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── Apple 로그인 (추후) ──────────────────────────────────
# Apple Developer Program 가입($99/년) 후 Services ID, Key ID, Team ID, .p8 키로
# client secret(JWT)을 직접 생성해야 합니다. 준비되면 src/auth.ts의 주석을 해제하세요.
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

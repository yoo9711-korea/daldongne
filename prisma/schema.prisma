generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?
  image               String?
  passwordHash        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  role                String               @default("USER")
  accounts            Account[]
  books               Book[]
  bookOrders          BookOrder[]
  productApplications ProductApplication[]
  familyMemberships   FamilyMember[]
  memories            Memory[]
  passwordResetTokens PasswordResetToken[]
  sessions            Session[]
  timeCapsules        TimeCapsule[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model BookProductionRequest {
  id        String                  @id @default(cuid())
  bookId    String
  authorId  String
  name      String?
  phone     String?
  email     String?
  message   String?
  status    ProductionRequestStatus @default(REQUESTED)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  bookOrder BookOrder?

  @@index([bookId])
  @@index([authorId])
  @@index([status])
  @@map("book_production_requests")
}

model ProductApplication {
  id                 String                  @id @default(cuid())
  userId             String
  productCode        String
  productName        String
  category           String
  billingType        String
  price              Int
  name               String?
  phone              String?
  email              String?
  message            String?
  addonCodes         Json?
  adminNote          String?
  adminNoteUpdatedAt DateTime?
  status             ProductionRequestStatus @default(REQUESTED)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([productCode])
  @@index([status])
  @@index([createdAt])
  @@map("product_applications")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Family {
  id           String             @id @default(cuid())
  name         String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  invitations  FamilyInvitation[]
  members      FamilyMember[]
  memories     Memory[]
  timeCapsules TimeCapsule[]

  @@map("families")
}

model FamilyMember {
  id       String     @id @default(cuid())
  familyId String
  userId   String
  role     FamilyRole @default(VIEWER)
  joinedAt DateTime   @default(now())
  family   Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@map("family_members")
}

model Memory {
  id           String       @id @default(cuid())
  type         MemoryType
  title        String?
  description  String?
  fileUrl      String?
  occurredAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  authorId     String
  familyId     String?
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  family       Family?      @relation(fields: [familyId], references: [id])
  bookMemories BookMemory[]

  @@index([authorId, occurredAt])
  @@map("memories")
}

model Book {
  id              String     @id @default(cuid())
  authorId        String
  type            BookType
  title           String
  subtitle        String?
  summary         String?
  content         String?
  coverText       String?
  status          BookStatus @default(DRAFT)
  pageCount       Int?
  basedPhotoCount Int?
  basedStoryCount Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  bookMemories BookMemory[]
  bookOrders   BookOrder[]

  @@index([authorId])
  @@map("books")
}

model BookOrder {
  id                  String          @id @default(cuid())
  productionRequestId String          @unique
  bookId              String
  authorId            String
  productType         BookProductType
  productName         String
  specification       String?
  quantity            Int             @default(1)
  productAmount       Int
  shippingFee         Int             @default(0)
  totalAmount         Int
  status              BookOrderStatus @default(READY)
  orderId             String          @unique
  paymentKey          String?         @unique
  paymentMethod       String?
  paidAt              DateTime?
  canceledAt          DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  productionRequest BookProductionRequest @relation(fields: [productionRequestId], references: [id], onDelete: Cascade)
  book              Book                  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author            User                  @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([authorId])
  @@index([status])
  @@map("book_orders")
}

model BookMemory {
  id        String   @id @default(cuid())
  bookId    String
  memoryId  String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@unique([bookId, memoryId])
  @@index([bookId])
  @@index([memoryId])
  @@map("book_memories")
}

model FamilyInvitation {
  id        String     @id @default(cuid())
  familyId  String
  email     String
  role      FamilyRole @default(VIEWER)
  token     String     @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())
  family    Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("family_invitations")
}

model TimeCapsule {
  id        String        @id @default(cuid())
  title     String
  message   String
  fileUrl   String?
  openAt    DateTime
  status    CapsuleStatus @default(LOCKED)
  openedAt  DateTime?
  isPrivate Boolean       @default(false)
  authorId  String
  familyId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  family    Family?       @relation(fields: [familyId], references: [id])

  @@index([authorId, openAt])
  @@map("time_capsules")
}

enum FamilyRole {
  OWNER
  EDITOR
  VIEWER
}

enum MemoryType {
  PHOTO
  VIDEO
  AUDIO
  TEXT
}

enum BookType {
  LIFE_BOOK
  FAMILY_BOOK
  COUPLE_BOOK
  BABY_BOOK
  TRAVEL_BOOK
  AI_MOVIE
}

enum BookStatus {
  DRAFT
  IN_PRODUCTION
  PUBLISHED
}

enum BookProductType {
  DIGITAL_MANUSCRIPT
  BASIC_SOFTCOVER
  CUSTOM_BOOK
}

enum BookOrderStatus {
  READY
  PAYMENT_PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  CANCELED
  FAILED
}

enum ProductionRequestStatus {
  REQUESTED
  CONTACTED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum CapsuleStatus {
  LOCKED
  OPENED
}

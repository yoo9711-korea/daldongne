generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String         @id @default(cuid())
  name              String?
  email             String?        @unique
  emailVerified     DateTime?
  image             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  role              String         @default("USER")
  accounts          Account[]
  books             Book[]
  familyMemberships FamilyMember[]
  memories          Memory[]
  sessions          Session[]
  timeCapsules      TimeCapsule[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Family {
  id           String             @id @default(cuid())
  name         String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  invitations  FamilyInvitation[]
  members      FamilyMember[]
  memories     Memory[]
  timeCapsules TimeCapsule[]

  @@map("families")
}

model FamilyMember {
  id       String     @id @default(cuid())
  familyId String
  userId   String
  role     FamilyRole @default(VIEWER)
  joinedAt DateTime   @default(now())
  family   Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
  @@map("family_members")
}

model Memory {
  id          String     @id @default(cuid())
  type        MemoryType
  title       String?
  description String?
  fileUrl     String?
  occurredAt  DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  authorId    String
  familyId    String?
  author      User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  family      Family?    @relation(fields: [familyId], references: [id])

  @@index([authorId, occurredAt])
  @@map("memories")
}

model Book {
  id        String     @id @default(cuid())
  authorId  String
  type      BookType
  title     String
  status    BookStatus @default(DRAFT)
  pageCount Int?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
  @@map("books")
}

model FamilyInvitation {
  id        String     @id @default(cuid())
  familyId  String
  email     String
  role      FamilyRole @default(VIEWER)
  token     String     @unique @default(cuid())
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime   @default(now())
  family    Family     @relation(fields: [familyId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("family_invitations")
}

model TimeCapsule {
  id        String        @id @default(cuid())
  title     String
  message   String
  fileUrl   String?
  openAt    DateTime
  status    CapsuleStatus @default(LOCKED)
  openedAt  DateTime?
  isPrivate Boolean       @default(false)
  authorId  String
  familyId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  author    User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  family    Family?       @relation(fields: [familyId], references: [id])

  @@index([authorId, openAt])
  @@map("time_capsules")
}

enum FamilyRole {
  OWNER
  EDITOR
  VIEWER
}

enum MemoryType {
  PHOTO
  VIDEO
  AUDIO
  TEXT
}

enum BookType {
  LIFE_BOOK
  FAMILY_BOOK
  COUPLE_BOOK
  BABY_BOOK
  TRAVEL_BOOK
  AI_MOVIE
}

enum BookStatus {
  DRAFT
  IN_PRODUCTION
  PUBLISHED
}

enum CapsuleStatus {
  LOCKED
  OPENED
}
